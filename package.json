{
  "name": "igv-geoportal",
  "version": "1.0.0",
  "description": "Geoportal de analise alfanumerica e espacial (PostGIS + GeoServer + Leaflet + Express) — Viana do Castelo. Trabalho pratico de Informacao Geografica e Visualizacao.",
  "private": true,
  "scripts": {
    "start": "node webserver/server.js",
    "dev": "node --watch webserver/server.js",
    "install:web": "npm install --prefix webserver",
    "up": "docker compose -f docker/docker-compose.yml up -d",
    "down": "docker compose -f docker/docker-compose.yml down",
    "logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:up": "docker compose -f docker/docker-compose.yml up -d db",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "dados:vetorial": "bash sql/03_importar_vetorial.sh",
    "dados:raster": "bash sql/04_importar_raster.sh",
    "geoserver:publicar": "bash scripts/publicar_geoserver.sh",
    "test": "node --test test/rotas.test.mjs",
    "test:smoke": "node test/smoke.mjs",
    "zip:submission": "node scripts/empacotar.mjs submission",
    "zip:full": "node scripts/empacotar.mjs full"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
